{
  "name": "scratch4js",
  "description": "The SB3 format for JavaScript.",
  "version": "1.0.1",
  "type": "module",
  "license": "MPL-2.0",
  "author": "playforge-coding",
  "homepage": "https://github.com/playforge-coding/scratch4js/tree/main/packages/scratch4js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/playforge-coding/scratch4js.git",
    "directory": "packages/scratch4js"
  },
  "bugs": {
    "url": "https://github.com/playforge-coding/scratch4js/issues"
  },
  "keywords": [
    "scratch",
    "sb3",
    "turbowarp",
    "scratch-blocks",
    "project",
    "editor"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./umd": "./dist/umd/index.js"
  },
  "main": "./dist/cjs/index.cjs",
  "types": "./dist/esm/index.d.ts",
  "unpkg": "./dist/umd/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rslib",
    "dev": "rslib --watch"
  },
  "devDependencies": {
    "@rslib/core": "^0.22.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@turbowarp/jszip": "^3.12.0"
  }
}
