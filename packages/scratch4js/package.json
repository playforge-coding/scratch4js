{
  "name": "scratch4js",
  "description": "The SB3 format for JavaScript.",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./umd": "./dist/umd/index.js"
  },
  "main": "./dist/cjs/index.cjs",
  "types": "./dist/esm/index.d.ts",
  "unpkg": "./dist/umd/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "dev": "rslib --watch"
  },
  "devDependencies": {
    "@rslib/core": "^0.22.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@turbowarp/jszip": "^3.12.0"
  }
}
