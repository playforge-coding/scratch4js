{
  // Plain-JS library: this config exists so rslib can emit `.d.ts` files from
  // the JSDoc types in `src/`. It is type-checking config only — no JS is built
  // by tsc (rslib/Rspack handles that).
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    // Emit declarations from our own JSDoc only — never auto-include ambient
    // `@types/*` packages hoisted into the workspace. A broken/partial one
    // (e.g. `@types/trusted-types`, pulled in transitively by a devDependency)
    // otherwise fails the build with TS2688.
    "types": [],
    "strict": true,
    "rootDir": "src"
  },
  "include": ["src"]
}
