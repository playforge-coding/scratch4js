{
  "name": "s-api4js",
  "description": "A class-based wrapper for the Scratch API: public data and login (edit project .sb3).",
  "version": "1.2.0",
  "type": "module",
  "license": "MPL-2.0",
  "author": "playforge-coding",
  "homepage": "https://github.com/playforge-coding/scratch4js/tree/main/packages/s-api4js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/playforge-coding/scratch4js.git",
    "directory": "packages/s-api4js"
  },
  "bugs": {
    "url": "https://github.com/playforge-coding/scratch4js/issues"
  },
  "keywords": [
    "scratch",
    "scratch-api",
    "api",
    "wrapper",
    "sb3",
    "login"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    }
  },
  "main": "./dist/cjs/index.cjs",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rslib",
    "dev": "rslib --watch"
  },
  "devDependencies": {
    "@rslib/core": "^0.22.0",
    "scratch4js": "workspace:*",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "tough-cookie": "^5.1.2"
  }
}
