{
  "name": "dev-local",
  "description": "A general-purpose in-browser code editor: edit a multi-file project in Monaco, run npm and a real shell in a WebContainer, build it, and live-preview the result. Built on the browser-ide-kit toolkit.",
  "version": "1.2.4",
  "type": "module",
  "private": true,
  "license": "MPL-2.0",
  "author": "playforge-coding",
  "homepage": "https://github.com/playforge-coding/scratch4js/tree/main/packages/dev-local#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/playforge-coding/scratch4js.git",
    "directory": "packages/dev-local"
  },
  "keywords": [
    "ide",
    "editor",
    "monaco",
    "webcontainer",
    "xterm",
    "playground",
    "browser-ide-kit"
  ],
  "scripts": {
    "dev": "rsbuild dev",
    "build": "rsbuild build",
    "preview": "rsbuild preview"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.5.0",
    "@rsbuild/plugin-node-polyfill": "^1.3.0",
    "@rsbuild/plugin-react": "^1.3.0",
    "@tailwindcss/postcss": "^4.1.0",
    "tailwindcss": "^4.1.0"
  },
  "dependencies": {
    "lucide-react": "^0.474.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "wasm-git": "^0.0.14",
    "browser-ide-kit": "workspace:*"
  }
}
